# Backboard
BACKBOARD_API_KEY=
BACKBOARD_BASE_URL=https://app.backboard.io/api

# Auth0
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_AUDIENCE=

# MongoDB Atlas
MONGODB_URI=
MONGODB_DB=custos

# Custos behavior
CUSTOS_BLOCK_ON=critical,high
CUSTOS_ALLOW_OVERRIDE=true
CUSTOS_AI_PATCHES=true
CUSTOS_AUDIT_ENABLED=true
